{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "moduleResolution": "Node16",
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,

    "esModuleInterop": true,
//    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src/**/*"],
}
